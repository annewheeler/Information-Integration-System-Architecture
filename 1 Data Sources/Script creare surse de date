import pandas as pd
import json

# 1. Încărcare date sursă
df_main = pd.read_csv('ai_company_adoption.csv')
df_industry = pd.read_csv('ai_industry_summary.csv')
df_country = pd.read_csv('country_ai_index.csv')

# --- DESTINAȚIA 1: PostgreSQL (Date Operaționale și Firmografice) ---
# Tabel 1: Firme (Dimensiune)
dim_companies = df_main[['company_id', 'industry', 'company_size', 'num_employees', 
                         'annual_revenue_usd_millions', 'company_founding_year', 
                         'company_age', 'company_age_group', 'country', 'region']].drop_duplicates()

# Tabel 2: Metadate Sondaj
fact_surveys = df_main[['response_id', 'company_id', 'survey_year', 'quarter', 
                        'survey_source', 'data_collection_method']]

# Tabel 3: Resurse Umane și Satisfacție
fact_workforce = df_main[['response_id', 'remote_work_percentage', 
                          'employee_satisfaction_score', 'reskilled_employees']]

# Tabel 4: Dinamica Locurilor de Muncă
fact_job_dynamics = df_main[['response_id', 'jobs_displaced', 'jobs_created']]

# Export CSV pentru import în Postgres
dim_companies.to_csv('pg_dim_companies.csv', index=False)
fact_surveys.to_csv('pg_fact_surveys.csv', index=False)
fact_workforce.to_csv('pg_fact_workforce.csv', index=False)
fact_job_dynamics.to_csv('pg_fact_jobs.csv', index=False)


# --- DESTINAȚIA 2: Oracle (Performanță, Finanțe și Eficiență) ---
# Tabel 1: Rezultate Business (KPIs)
fact_ai_performance = df_main[['response_id', 'productivity_change_percent', 'revenue_growth_percent', 
                               'cost_reduction_percent', 'innovation_score', 'customer_satisfaction']]

# Tabel 2: Investiții AI
fact_ai_finance = df_main[['response_id', 'ai_budget_percentage', 'ai_investment_per_employee']]

# Tabel 3: Metrici de Eficiență Operațională
fact_ai_efficiency = df_main[['response_id', 'ai_projects_active', 'ai_training_hours', 
                              'time_saved_per_week', 'task_automation_rate']]

# Export CSV pentru import în Oracle
fact_ai_performance.to_csv('ora_fact_performance.csv', index=False)
fact_ai_finance.to_csv('ora_fact_finance.csv', index=False)
fact_ai_efficiency.to_csv('ora_fact_efficiency.csv', index=False)


# --- DESTINAȚIA 3: MongoDB (Adopție Tehnologică și Guvernanță) ---
# Aici folosim Obiecte Imbricate și LISTE (Arrays)
mongo_docs = []

for _, row in df_main.iterrows():
    doc = {
        "response_id": int(row['response_id']),
        "company_id": row['company_id'],
        
        # OBIECT IMBRICAT: Metrici de adopție
        "adoption_metrics": {
            "rate": row['ai_adoption_rate'],
            "stage": row['ai_adoption_stage'],
            "years_active": row['years_using_ai'],
            "maturity_score": row['ai_maturity_score'],
            "failure_rate": row['ai_failure_rate']
        },
        
        # TEHNOLOGIE CU LISTE (ARRAYS):
        # Chiar dacă în CSV avem un singur tool, în Mongo îl reprezentăm ca listă 
        # pentru a permite extensibilitatea (ex: [Tool1, Tool2])
        "tech_stack": {
            "main_tools": [row['ai_primary_tool']], # LISTA (Array)
            "tools_count": int(row['num_ai_tools_used']),
            "use_cases": [row['ai_use_case']] # LISTA (Array)
        },
        
        # OBIECT IMBRICAT: Guvernanță și Risc
        "governance_and_compliance": {
            "compliance_score": row['regulatory_compliance_score'],
            "privacy_level": row['data_privacy_level'],
            "ethics_committee": row['ai_ethics_committee'],
            "risk_score": row['ai_risk_management_score'],
            # Putem adăuga și o listă de audit tags
            "audit_tags": ["GDPR_Checked" if row['regulatory_compliance_score'] > 70 else "Audit_Required"]
        }
    }
    mongo_docs.append(doc)

# Salvare ca JSON ierarhic pentru MongoDB
with open('mongo_ai_details.json', 'w') as f:
    json.dump(mongo_docs, f, indent=4)


# --- DESTINAȚIA 4: Fișiere Externe (Date Macro și de Referință) ---
df_industry.to_csv('ref_industry_summary.csv', index=False)
df_country.to_excel('ref_country_index.xlsx', index=False)

print("Succes! Datele au fost fragmentate în 4 surse eterogene.")
print("Verificare coloane: Toate cele 43 de atribute au fost mapate.")
